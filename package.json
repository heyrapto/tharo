{
  "name": "tharo",
  "version": "1.0.0",
  "description": "The high-performance, local-first utility belt for AI Agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "nlp",
    "intent",
    "entity-extraction",
    "pii",
    "guard",
    "middleware",
    "text-processing",
    "chatbot",
    "typescript"
  ],
  "dependencies": {
    "natural": "^6.12.0"
  },
  "devDependencies": {
    "@types/natural": "^5.1.5",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heyrapto/tharo.git"
  },
  "bugs": {
    "url": "https://github.com/heyrapto/tharo/issues"
  },
  "homepage": "https://github.com/heyrapto/tharo#readme"
}